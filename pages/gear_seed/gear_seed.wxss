/* pages/gear_seed/gear_seed.wxss */
.seed-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--c-border);
}
.seed-item:last-child { border-bottom: none; }
.seed-left { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.seed-name { font-size: 28rpx; font-weight: 500; color: var(--c-text); }
.seed-meta { font-size: 22rpx; }
.seed-spec { font-size: 22rpx; flex-shrink: 0; }
.seed-result { display: block; font-size: 28rpx; line-height: 1.8; white-space: pre-line; }
.tip { display: block; font-size: 24rpx; margin-top: 24rpx; line-height: 1.5; }
