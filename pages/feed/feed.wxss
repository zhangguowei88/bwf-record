/* pages/feed/feed.wxss — 球友圈 */

.loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 160rpx 0;
}
.loading-spinner {
  width: 64rpx; height: 64rpx;
  border: 6rpx solid #e5e7eb; border-top-color: #10b981;
  border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 24rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }

.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; color: #6b7280; display: block; margin-bottom: 8rpx; }

/* 动态卡片 */
.feed-item { padding: 28rpx 32rpx; }
.feed-head { display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx; }
.feed-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #fff; flex-shrink: 0;
}
.feed-author { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.feed-name-row { display: flex; align-items: center; gap: 10rpx; }
.feed-name { font-size: 30rpx; font-weight: 600; color: #1f2937; }
.feed-mine-tag {
  font-size: 18rpx; color: #fff; background: #10b981;
  padding: 2rpx 10rpx; border-radius: 8rpx;
}
.feed-meta { display: flex; align-items: center; gap: 10rpx; }
.feed-level { font-size: 22rpx; font-weight: 500; }
.feed-time { font-size: 22rpx; }

/* 内容 */
.feed-body { margin-bottom: 20rpx; }
.feed-info { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.feed-date { font-size: 26rpx; color: #6b7280; }
.feed-duration { font-size: 28rpx; font-weight: 600; color: #1f2937; }
.feed-chip { padding: 4rpx 16rpx; border-radius: 16rpx; font-size: 22rpx; }
.chip-intensity-1 { background: #f3f4f6; color: #6b7280; }
.chip-intensity-2 { background: #dbeafe; color: #1d4ed8; }
.chip-intensity-3 { background: #fee2e2; color: #b91c1c; }
.chip-feeling-1 { background: #d1fae5; color: #059669; }
.chip-feeling-2 { background: #fef3c7; color: #b45309; }
.chip-feeling-3 { background: #fee2e2; color: #b91c1c; }
.feed-venue { display: block; font-size: 24rpx; margin-bottom: 8rpx; }
.feed-note { display: block; font-size: 28rpx; color: #374151; line-height: 1.7; }

/* 互动 */
.feed-actions { display: flex; gap: 40rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f6f8; }
.action-btn { display: flex; align-items: center; gap: 8rpx; padding: 8rpx 0; }
.action-icon { font-size: 32rpx; }
.action-text { font-size: 26rpx; color: #6b7280; }
.action-btn.liked .action-text { color: #ef4444; }
.action-share {
  margin-left: auto; background: transparent; line-height: normal;
  border: none; padding: 8rpx 0;
}
.action-share::after { border: none; }
.action-more { padding: 8rpx 4rpx; }

.loading-more { text-align: center; padding: 32rpx; }

/* ===== 评论弹窗 ===== */
.sheet-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); opacity: 0; visibility: hidden;
  transition: all 0.25s; z-index: 100;
}
.sheet-mask.show { opacity: 1; visibility: visible; }

.comment-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh; display: flex; flex-direction: column;
  transform: translateY(100%); transition: transform 0.3s;
  z-index: 101; padding-bottom: env(safe-area-inset-bottom);
}
.comment-sheet.show { transform: translateY(0); }

.comment-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; border-bottom: 1rpx solid #f0f1f3; flex-shrink: 0;
}
.comment-title { font-size: 32rpx; font-weight: 600; color: #1f2937; }
.comment-close { font-size: 36rpx; color: #9ca3af; padding: 0 8rpx; }

.comment-list { flex: 1; max-height: 600rpx; padding: 16rpx 32rpx; }
.comment-empty { text-align: center; padding: 40rpx 0; font-size: 26rpx; }
.comment-item {
  padding: 20rpx 0; border-bottom: 1rpx solid #f5f6f8;
  display: flex; flex-direction: column; gap: 6rpx;
}
.comment-item:last-child { border-bottom: none; }
.comment-author { font-size: 26rpx; font-weight: 600; color: #10b981; }
.comment-content { font-size: 28rpx; color: #1f2937; line-height: 1.6; }
.comment-time { font-size: 22rpx; }

.comment-input-row {
  display: flex; gap: 16rpx; padding: 20rpx 32rpx 32rpx;
  border-top: 1rpx solid #f0f1f3; align-items: center;
}
.comment-input {
  flex: 1; height: 72rpx; background: #f5f7fa;
  border-radius: 36rpx; padding: 0 28rpx; font-size: 28rpx;
}
.comment-send {
  width: 120rpx; height: 72rpx; line-height: 72rpx;
  background: #10b981; color: #fff; border-radius: 36rpx;
  font-size: 28rpx; padding: 0;
}
.comment-send::after { border: none; }

/* 九宫格媒体 */
.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
}
/* 单图/单视频时不大图展示，保持格子统一 */
.media-count-1 .media-cell,
.media-count-2 .media-cell {
  /* 仍用三列网格，前1-2个格子 */
}
.media-cell {
  position: relative;
  width: 100%;
  padding-bottom: 100%;   /* 正方形 */
  border-radius: 12rpx;
  overflow: hidden;
  background: #f3f4f6;
}
.media-cell-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.media-cell-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 40rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6);
}
