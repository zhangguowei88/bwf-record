/* pages/gear/gear.wxss — 装备评测主页 */

.search-bar {
  margin-bottom: 16rpx;
}
.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  box-shadow: var(--shadow);
}

.cat-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}
.cat-tabs {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx;
}
.cat-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #fff;
  color: var(--c-text-sub);
  font-size: 26rpx;
  white-space: nowrap;
}
.cat-tab.active {
  background: var(--c-primary);
  color: #fff;
  font-weight: 600;
}

/* 装备卡片 */
.gear-item {
  display: flex;
  gap: 20rpx;
  background: var(--c-card);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}
.gear-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f3f4f6;
}
.gear-cover-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}
.gear-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.gear-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.gear-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--c-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.gear-cat-tag {
  font-size: 20rpx;
  color: var(--c-primary-dark);
  background: var(--c-primary-light);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.gear-brand {
  font-size: 24rpx;
}
.gear-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.gear-score {
  font-size: 28rpx;
  font-weight: 600;
}
.gear-count {
  font-size: 24rpx;
}


/* 装备匹配入口 */
.match-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, var(--c-primary-light), #fff);
  margin-bottom: 20rpx;
}
.match-entry-left { display: flex; align-items: center; gap: 20rpx; }
.match-entry-icon { font-size: 48rpx; }
.match-entry-info { display: flex; flex-direction: column; gap: 4rpx; }
.match-entry-title { font-size: 32rpx; font-weight: 600; color: var(--c-primary-dark); }
.match-entry-desc { font-size: 24rpx; }
.match-entry-arrow { font-size: 40rpx; color: var(--c-primary); }
