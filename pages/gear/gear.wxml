<!-- pages/gear/gear.wxml — 装备评测主页 -->
<view class="container safe-bottom">

  <!-- 搜索 -->
  <view class="search-bar">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput"
      bindconfirm="onSearchConfirm" placeholder="搜索球拍 / 球鞋 / 羽毛球..." confirm-type="search" />
  </view>

  <!-- 分类 -->
  <scroll-view scroll-x class="cat-scroll" enhanced show-scrollbar="{{false}}">
    <view class="cat-tabs">
      <view wx:for="{{categories}}" wx:key="value"
        class="cat-tab {{category === item.value ? 'active' : ''}}"
        data-value="{{item.value}}" bindtap="pickCategory">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 装备列表 -->
  <view wx:if="{{loading && !list.length}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="text-light">加载中...</text>
  </view>

  <view wx:if="{{!loading && !list.length}}" class="empty">
    <view class="empty-icon">🏸</view>
    <text class="empty-text">还没有装备</text>
    <text class="text-light">可在后台录入装备，或在装备详情页申请补充</text>
  </view>

  <view wx:for="{{list}}" wx:key="_id" class="gear-item" data-id="{{item._id}}" bindtap="goGearDetail">
    <image wx:if="{{item.cover_file_id}}" class="gear-cover" src="{{item.cover_file_id}}" mode="aspectFill" />
    <view wx:else class="gear-cover gear-cover-ph">🏸</view>
    <view class="gear-info">
      <view class="gear-name-row">
        <text class="gear-name">{{item.name}}</text>
        <text class="gear-cat-tag">{{item.category_name}}</text>
      </view>
      <text class="gear-brand text-light" wx:if="{{item.brand}}">{{item.brand}}</text>
      <view class="gear-meta">
        <text class="gear-score" style="color:{{item.score_color}};">★ {{item.score_text}}</text>
        <text class="gear-count text-light">{{item.review_count}} 条评测</text>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="loading-more text-light">加载中...</view>
  <view wx:if="{{!loading && list.length && !hasMore}}" class="loading-more text-light">— 没有更多了 —</view>
</view>
