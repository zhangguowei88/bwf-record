/* pages/gear_match/gear_match.wxss */

.match-progress {
  position: relative;
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}
.match-progress .text-light {
  position: absolute;
  top: -36rpx;
  right: 0;
  font-size: 24rpx;
}
.match-progress-bar {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: var(--c-primary);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.match-q-card { text-align: center; }
.match-q-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 40rpx;
}
.match-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.match-option {
  padding: 28rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  font-size: 30rpx;
  color: var(--c-text);
  border: 2rpx solid transparent;
}
.match-option.active {
  background: var(--c-primary-light);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
  font-weight: 600;
}

/* 结果 */
.match-result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text);
  margin: 16rpx 0 24rpx;
}
.match-gear-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}
.match-rank {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.match-gear-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.match-gear-name { font-size: 30rpx; font-weight: 500; color: var(--c-text); }
.match-gear-meta { font-size: 24rpx; }
.match-gear-tags { display: flex; gap: 8rpx; margin-top: 4rpx; }
.match-tag { font-size: 20rpx; color: var(--c-text-sub); background: #f3f4f6; padding: 2rpx 12rpx; border-radius: 8rpx; }
.match-gear-score { font-size: 28rpx; font-weight: 600; flex-shrink: 0; }

.match-avoid-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-warn);
  margin: 40rpx 0 24rpx;
}
.match-avoid-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fffbeb;
}
.match-avoid-tag { font-size: 24rpx; color: var(--c-warn); flex-shrink: 0; }
