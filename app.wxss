/* app.wxss — 全局样式 · 简约清新设计系统 */

page {
  background: #f5f7fa;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ===== 主题色变量 ===== */
/* emerald 主色 · 健康 / sky 数据蓝 · amber 不足 · rose 过量 */
page {
  --c-primary: #10b981;
  --c-primary-light: #d1fae5;
  --c-primary-dark: #059669;
  --c-info: #3b82f6;
  --c-warn: #f59e0b;
  --c-danger: #ef4444;
  --c-text: #1f2937;
  --c-text-sub: #6b7280;
  --c-text-light: #9ca3af;
  --c-bg: #f5f7fa;
  --c-card: #ffffff;
  --c-border: #e5e7eb;
  --radius: 24rpx;
  --shadow: 0 4rpx 20rpx rgba(16, 24, 40, 0.06);
}

/* ===== 通用容器 ===== */
.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 卡片 ===== */
.card {
  background: var(--c-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ===== 按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  transition: opacity 0.2s;
}

.btn::after { border: none; }

.btn-primary {
  background: var(--c-primary);
  color: #fff;
}

.btn-primary[disabled] {
  background: var(--c-primary-light);
  color: #fff;
}

.btn-ghost {
  background: var(--c-primary-light);
  color: var(--c-primary-dark);
}

.btn-block { width: 100%; }

/* ===== 文字 ===== */
.text-sub { color: var(--c-text-sub); font-size: 26rpx; }
.text-light { color: var(--c-text-light); font-size: 24rpx; }
.text-lg { font-size: 36rpx; font-weight: 600; }
.text-xl { font-size: 48rpx; font-weight: 700; }
.text-primary { color: var(--c-primary); }
.text-warn { color: var(--c-warn); }
.text-danger { color: var(--c-danger); }

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.tag-success { background: #d1fae5; color: #059669; }
.tag-warn { background: #fef3c7; color: #b45309; }
.tag-danger { background: #fee2e2; color: #b91c1c; }

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--c-border);
  margin: 24rpx 0;
}

/* ===== 空状态 ===== */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: var(--c-text-light);
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

/* ===== 安全距离 ===== */
.safe-bottom { padding-bottom: calc(48rpx + env(safe-area-inset-bottom)); }
